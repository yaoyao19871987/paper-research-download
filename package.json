{
  "name": "paper-download",
  "version": "1.0.0",
  "description": "CNKI topic research pipeline and Sixue legacy download automation",
  "scripts": {
    "legacy-download": "node src/legacy-sixue-download.js",
    "pipeline": "node src/pipeline-runner.js",
    "pipeline:dev": "set PAPER_ENV=dev&& node src/pipeline-runner.js",
    "pipeline:test": "set PAPER_ENV=test&& node src/pipeline-runner.js",
    "pipeline:prod": "set PAPER_ENV=prod&& node src/pipeline-runner.js"
  },
  "keywords": [
    "playwright",
    "automation",
    "download"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.5",
    "playwright": "^1.52.0"
  }
}
