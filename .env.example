SITE_BASE_URL=http://www.sixuexiazai.com/
LOGIN_URL=http://www.sixuexiazai.com/

# Account
# Encrypted vault path: D:/Code/public/{secrets,keys}/sixue_credentials_*
USERNAME=
PASSWORD=

# Optional direct paper page URL (legacy direct downloader only)
PAPER_URL=

# Legacy Sixue downloader input
LEGACY_QUERY=
LEGACY_TITLE=

# Active environment: dev / test / prod
PAPER_ENV=dev

# Shared directories can be overridden in .env.<env>
DOWNLOAD_DIR=./downloads
AUTH_STATE_PATH=./state/auth.json
CNKI_OUTPUT_ROOT=./python-scraper/cnkiLRspider/outputs
WORK_REPORT_DIR=./work-reports

# Browser mode
HEADED=true

# Live mode phrase
CAPTCHA_READY_PHRASE=

# Navigation / polling
NAV_TIMEOUT_MS=120000
POLL_INTERVAL_MS=2000

# Login / captcha retries
LIBRARY_LOGIN_MAX_ATTEMPTS=5
LIBRARY_CAPTCHA_MAX_ATTEMPTS=3
LIBRARY_CAPTCHA_REFRESH_WAIT_MS=1200
LIBRARY_CAPTCHA_POST_FILL_WAIT_MS=800
LIBRARY_CAPTCHA_VERIFY_WAIT_MS=1800
LIBRARY_LOGIN_POST_SUBMIT_WAIT_MS=2200

# Adaptive waiting for long-running downloads
DOWNLOAD_SOFT_TIMEOUT_MS=600000
DOWNLOAD_HARD_TIMEOUT_MS=3600000
WAIT_PROGRESS_GRACE_MS=180000
DOWNLOAD_START_TIMEOUT_MS=15000
